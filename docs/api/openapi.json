  "info": {
    "contact": {
      "email": "byron@williamscpa.com",
      "name": "Byron Williams",
      "url": "https://github.com/ByronWilliamsCPA/llc-manager"
    },
    "description": "REST API for managing LLC entities, ownership structures, compliance dates, bank accounts, tax filings, and associated documentation.\n\nAll resource endpoints are namespaced under `/api/v1/` to match the API version `1.0.0`. Health probe endpoints are exposed under `/api/health/` and follow Kubernetes probe conventions.",
    "license": {
      "name": "MIT",
      "url": "https://github.com/ByronWilliamsCPA/llc-manager/blob/main/LICENSE"
    },
    "title": "LLC Manager API",
    "version": "1.0.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/health/live": {
      "get": {
        "description": "Indicates if the application is running. Used by Kubernetes liveness probe.",
        "operationId": "liveness_api_health_live_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Liveness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/health/ready": {
      "get": {
        "description": "Checks if the application can serve traffic. Used by Kubernetes readiness probe.",
        "operationId": "readiness_api_health_ready_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReadinessStatus"
                }
              }
            },
            "description": "Application is ready to serve traffic"
          },
          "503": {
            "description": "Application is not ready (dependencies unavailable)"
          }
        },
        "summary": "Readiness probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/health/startup": {
      "get": {
        "description": "Indicates if the application has completed startup. Used by Kubernetes startup probe.",
        "operationId": "startup_api_health_startup_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthStatus"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Startup probe",
        "tags": [
          "Health"
        ]
      }
    },
    "/api/v1/entities": {
      "get": {
        "description": "Return a paginated, optionally filtered list of LLC entities. Supports full-text search across `legal_name`, `ein`, and `dba_names`, plus an `is_active` filter. Soft-deleted entities are excluded.",
        "operationId": "list_entities_api_v1_entities_get",
        "parameters": [
          {
            "description": "Page number",
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "default": 1,
              "description": "Page number",
              "minimum": 1,
              "title": "Page",
              "type": "integer"
            }
          },
          {
            "description": "Items per page",
            "in": "query",
            "name": "size",
            "required": false,
            "schema": {
              "default": 20,
              "description": "Items per page",
              "maximum": 100,
              "minimum": 1,
              "title": "Size",
              "type": "integer"
            }
          },
          {
            "description": "Search by legal name or EIN",
            "in": "query",
            "name": "search",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Search by legal name or EIN",
              "title": "Search"
            }
          },
          {
            "description": "Filter by active status",
            "in": "query",
            "name": "is_active",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "boolean"
                },
