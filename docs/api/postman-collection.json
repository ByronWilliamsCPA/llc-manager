                  "    var body = pm.response.json();",
                  "    pm.expect(body, \"JSON body\").to.satisfy(function (value) {",
                  "        return value !== null && (typeof value === \"object\" || Array.isArray(value));",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "name": "Liveness probe",
          "request": {
            "description": "Indicates if the application is running. Used by Kubernetes liveness probe.",
            "header": [
              {
                "key": "Accept",
                "type": "text",
                "value": "application/json"
              },
              {
                "description": "Supplied via Postman environment variable.",
                "key": "X-API-Key",
                "type": "text",
                "value": "{{apiKey}}"
              }
            ],
            "method": "GET",
            "url": {
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "live"
              ],
              "query": [],
              "raw": "{{baseUrl}}/api/health/live",
              "variable": []
            }
          },
          "response": []
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Readiness probe returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Readiness probe returns a JSON body\", function () {",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "    var body = pm.response.json();",
                  "    pm.expect(body, \"JSON body\").to.satisfy(function (value) {",
                  "        return value !== null && (typeof value === \"object\" || Array.isArray(value));",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "name": "Readiness probe",
          "request": {
            "description": "Checks if the application can serve traffic. Used by Kubernetes readiness probe.",
            "header": [
              {
                "key": "Accept",
                "type": "text",
                "value": "application/json"
              },
              {
                "description": "Supplied via Postman environment variable.",
                "key": "X-API-Key",
                "type": "text",
                "value": "{{apiKey}}"
              }
            ],
            "method": "GET",
            "url": {
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "ready"
              ],
              "query": [],
              "raw": "{{baseUrl}}/api/health/ready",
              "variable": []
            }
          },
          "response": []
        },
        {
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Startup probe returns 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Startup probe returns a JSON body\", function () {",
                  "    pm.response.to.be.withBody;",
                  "    pm.response.to.be.json;",
                  "    var body = pm.response.json();",
                  "    pm.expect(body, \"JSON body\").to.satisfy(function (value) {",
                  "        return value !== null && (typeof value === \"object\" || Array.isArray(value));",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "name": "Startup probe",
          "request": {
            "description": "Indicates if the application has completed startup. Used by Kubernetes startup probe.",
            "header": [
              {
                "key": "Accept",
                "type": "text",
                "value": "application/json"
              },
              {
                "description": "Supplied via Postman environment variable.",
                "key": "X-API-Key",
                "type": "text",
                "value": "{{apiKey}}"
              }
            ],
            "method": "GET",
            "url": {
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health",
                "startup"
              ],
              "query": [],
              "raw": "{{baseUrl}}/api/health/startup",
              "variable": []
            }
          },
          "response": []
        }
      ],
      "name": "Health"
    }
  ],
  "variable": [
    {
      "description": "Base URL of the LLC Manager API.",
      "key": "baseUrl",
      "type": "string",
      "value": "http://localhost:8000"
    },
    {
      "description": "API key sent as the X-API-Key header.",
      "key": "apiKey",
      "type": "string",
      "value": ""
    }
  ]
}
